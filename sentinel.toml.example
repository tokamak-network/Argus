# Argus Sentinel — Example Configuration
#
# Copy this file to `sentinel.toml` and adjust values for your deployment.
# All fields use serde defaults — omitted fields get sensible defaults.
#
# Usage:
#   argus sentinel --rpc https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY \
#                  --config sentinel.toml

[sentinel]
enabled = true

# ---------------------------------------------------------------------------
# Pre-filter heuristics (fast receipt-based screening, ~10-50us per TX)
# ---------------------------------------------------------------------------
[sentinel.prefilter]
# Minimum combined heuristic score to flag a TX for deep analysis [0.0 - 1.0].
# Lower = more sensitive (more alerts), higher = fewer false positives.
suspicion_threshold = 0.5

# Minimum ETH value to trigger the high-value-transfer heuristic.
min_value_eth = 1.0

# Minimum gas used to trigger gas-related heuristics.
min_gas_used = 500000

# Minimum ERC-20 Transfer events to flag token-heavy TXs.
min_erc20_transfers = 5

# Gas used/limit ratio above which a TX is flagged as unusual [0.0 - 1.0].
gas_ratio_threshold = 0.95

# MEV bot suppression: multiplicative discount for known MEV patterns.
# FlashLoan arbitrage: flash loan + known protocol + large ERC20 routing.
# Set to 1.0 to disable. Lower = more aggressive suppression.
mev_flash_loan_factor = 0.15

# SelfDestruct cleanup: SelfDestruct + HighValueRevert without flash loan.
# Set to 1.0 to disable.
mev_selfdestruct_factor = 0.25

# ---------------------------------------------------------------------------
# Deep analysis engine (opcode-level replay on flagged TXs)
# ---------------------------------------------------------------------------
[sentinel.analysis]
# Maximum opcode steps before aborting replay (safety limit).
max_steps = 1000000

# Minimum classifier confidence to emit an alert [0.0 - 1.0].
min_alert_confidence = 0.4

# Emit lightweight alerts from pre-filter when deep analysis is unavailable.
# Useful for RPC mode without archive node access.
prefilter_alert_mode = true

# ---------------------------------------------------------------------------
# Alert output destinations
# ---------------------------------------------------------------------------
[sentinel.alert]
# Path for append-only JSONL alert log. Comment out to disable.
jsonl_path = "/var/log/argus/alerts.jsonl"

# Webhook URL for Slack, Discord, or PagerDuty. Comment out to disable.
# webhook_url = "https://hooks.slack.com/services/T.../B.../xxx"

# Maximum alerts per minute (rate limiter).
rate_limit_per_minute = 30

# Suppress duplicate alerts for the same TX within this many blocks.
dedup_window_blocks = 10

# ---------------------------------------------------------------------------
# Mempool monitoring (pre-execution scanning)
# NOTE: Only used in Store mode (ethrex-embedded). Not wired in RPC-mode
# CLI sentinel. Included for reference; ignored when using `argus sentinel`.
# ---------------------------------------------------------------------------
[sentinel.mempool]
enabled = false
min_value_eth = 10.0
min_gas = 500000

# ---------------------------------------------------------------------------
# Auto-pause circuit breaker
# NOTE: Only used in Store mode (ethrex-embedded). Not wired in RPC-mode
# CLI sentinel. Included for reference; ignored when using `argus sentinel`.
# WARNING: Enabling auto-pause on a validator node risks slashing penalties.
# Only enable if you understand the implications for your infrastructure.
# ---------------------------------------------------------------------------
[sentinel.auto_pause]
enabled = false
confidence_threshold = 0.9
priority_threshold = "Critical"

# ---------------------------------------------------------------------------
# Adaptive ML pipeline (experimental)
# NOTE: Not wired in current CLI sentinel path. Placeholder for future use.
# ---------------------------------------------------------------------------
[sentinel.pipeline]
enabled = false
# model_path = "/opt/argus/models/prefilter-v1.onnx"
max_pipeline_ms = 100

# ---------------------------------------------------------------------------
# DeFi protocol whitelist (false-positive reduction)
#
# Known DeFi protocols that legitimately trigger heuristics (flash loans,
# high-volume swaps, etc.). Each entry reduces the suspicion score by
# `score_modifier` when the TX interacts with the whitelisted address.
#
# Categories: FlashLoan, DEX, Lending, Bridge
# ---------------------------------------------------------------------------
[sentinel.whitelist]

[[sentinel.whitelist.entries]]
protocol = "Aave V3 Pool"
address = "0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2"
category = "Lending"
score_modifier = -0.3

[[sentinel.whitelist.entries]]
protocol = "Uniswap V3 Router"
address = "0xE592427A0AEce92De3Edee1F18E0157C05861564"
category = "DEX"
score_modifier = -0.2

[[sentinel.whitelist.entries]]
protocol = "Balancer Vault"
address = "0xBA12222222228d8Ba445958a75a0704d566BF2C8"
category = "FlashLoan"
score_modifier = -0.25

# ---------------------------------------------------------------------------
# AI Agent (requires `ai_agent` feature flag)
#
# 2-tier LLM pipeline: screening model (cheap/fast) escalates to deep model
# (accurate) when confidence exceeds threshold. Budget controls prevent
# runaway costs. Enable with `argus sentinel --ai`.
# ---------------------------------------------------------------------------
[sentinel.ai]
enabled = false
backend = "litellm"
screening_model = "gemini-3-flash"
deep_model = "gemini-3-pro"
is_suspicious_confidence_threshold = 0.6
monthly_budget_usd = 150.0
daily_limit_usd = 10.0
hourly_rate_limit = 100
max_concurrent_per_block = 3
request_timeout_secs = 30
max_retries = 3
# litellm_api_base = "https://your-litellm-proxy.example.com"
# litellm_api_key_env = "LITELLM_API_KEY"

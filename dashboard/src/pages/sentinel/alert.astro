---
import SentinelLayout from "../../layouts/SentinelLayout.astro";
import SentinelHeader from "../../components/sentinel/SentinelHeader";
import SentinelFooter from "../../components/sentinel/SentinelFooter";
import AlertDetail from "../../components/sentinel/AlertDetail";

const sentinelApi = import.meta.env.PUBLIC_SENTINEL_API || '';
---

<SentinelLayout title="Alert Analysis — Argus Sentinel" currentPath="/sentinel/history">
  <SentinelHeader slot="header" currentPath="/sentinel/history" client:load />

  <AlertDetail
    client:load
    {...(sentinelApi ? { apiBase: `${sentinelApi}/sentinel/history` } : {})}
  />

  <SentinelFooter slot="footer" client:load />
</SentinelLayout>
